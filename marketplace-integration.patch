+          {/* Spec sheet — the instrument panel */}
+          <dl className="mt-6 grid grid-cols-2 gap-x-6 gap-y-3 rounded-2xl border border-slate-100 bg-white shadow-sm p-5 sm:grid-cols-4">
+            {specs.map(([label, value]) => (
