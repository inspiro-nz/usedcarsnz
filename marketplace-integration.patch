+          disabled={pending}
+          className="shrink-0 rounded-lg bg-orange-500 px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-orange-600 disabled:opacity-50"
+        >
+          {pending ? "Sending…" : "Approve & send"}
+        </button>
+      </div>
+    </form>
+  );
+}
